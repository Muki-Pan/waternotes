---
import "../styles/global.css";
import PhotographicNoteCard from "../components/PhotographicNoteCard.astro";
import SiteNav from "../components/SiteNav.astro";
import { records } from "../data/records.js";
const archiveCity = (city = "") => String(city).trim();
const visitDate = (record) => record.visitDate || record.visit_date || "";
const timestamp = (record) => visitDate(record) ? new Date(`${visitDate(record)}T00:00:00`).getTime() : -Infinity;
const formatGroupDate = (date) =>
  new Intl.DateTimeFormat("en", { month: "short", day: "2-digit" })
    .format(new Date(`${date}T00:00:00`))
    .toUpperCase();

function groupArchive(sourceRecords) {
  const dated = sourceRecords.filter((record) => visitDate(record)).sort((a, b) => timestamp(b) - timestamp(a));
  const undated = sourceRecords.filter((record) => !visitDate(record));
  const sections = new Map();

  dated.forEach((record) => {
    const date = visitDate(record);
    const year = date.slice(0, 4);
    if (!sections.has(year)) sections.set(year, new Map());
    const groupKey = `${date}::${archiveCity(record.city)}`;
    const groups = sections.get(year);
    if (!groups.has(groupKey)) groups.set(groupKey, { date, city: record.city?.trim() || "", records: [] });
    groups.get(groupKey).records.push(record);
  });

  const result = Array.from(sections, ([year, groups]) => ({ year, groups: Array.from(groups.values()) }));
  if (undated.length) result.push({ year: "undated", groups: [{ date: "", city: "", records: undated }] });
  return result;
}

const archiveSections = groupArchive(records);
const years = archiveSections.filter((section) => section.year !== "undated").map((section) => section.year);
const fallbackRecords = JSON.stringify(records);
const supabaseConfig = JSON.stringify({
  url: import.meta.env.PUBLIC_SUPABASE_URL || "",
  publishableKey:
    import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY || import.meta.env.PUBLIC_SUPABASE_ANON_KEY || "",
  bucket: import.meta.env.PUBLIC_SUPABASE_BUCKET || "field-notes",
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>All Notes | Water Notes</title>
    <meta name="description" content="Browse Water Notes by visit date and city." />
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body class="archive-page is-syncing-records">
    <main class="page-shell archive-shell">
      <SiteNav current="archive" />
      <section class="archive-heading">
        <div>
          <nav class="archive-year-index" aria-label="Archive years">
            {years.map((year) => <a href={`#archive-year-${year}`}>{year}</a>)}
          </nav>
        </div>
        <div class="archive-create-tools" id="archive-create-tools" hidden>
          <select id="create-note-type" aria-label="New note type">
            <option value="exhibition">Exhibition Note</option>
            <option value="photographic">Photographic Note</option>
          </select>
          <button class="button create-note-button" id="create-note" type="button">Create Note</button>
        </div>
      </section>

      <div class="archive-timeline" id="archive-timeline" aria-label="Notes grouped by visit date and city">
        {archiveSections.map((section) => (
          <section class="archive-year" id={`archive-year-${section.year}`} data-archive-year={section.year}>
            <h2>{section.year === "undated" ? "Undated / 日期未定" : section.year}</h2>
            <div class="archive-year__groups">
              {section.groups.map((group) => (
                <section class="archive-group">
                  <header class="archive-group__header">
                    <h3>{group.date ? formatGroupDate(group.date) : "Undated / 日期未定"}</h3>
                    {group.city && <p>{group.city}</p>}
                  </header>
                  <div class="archive-group__records">
                    {group.records.map((record) =>
                      (record.note_type || record.noteType) === "photographic" ? (
                        <PhotographicNoteCard record={record} />
                      ) : (
                        <article class="archive-record" data-record-id={record.id}>
                          <a class="record-cover" href={`/record/?id=${record.id}`}>
                            <img class="smooth-image" src={record.images?.[0]?.src || ""} alt="" loading="lazy"
                              decoding="async" data-cover-record={record.id} hidden={!record.images?.[0]?.src} />
                          </a>
                          <div class="archive-record__copy">
                            <a class="record-row__title" href={`/record/?id=${record.id}`}>{record.title}</a>
                            {record.institution && <p class="archive-record__institution">{record.institution}</p>}
                            {record.summary && <p class="record-row__summary">{record.summary}</p>}
                          </div>
                        </article>
                      )
                    )}
                  </div>
                </section>
              ))}
            </div>
          </section>
        ))}
      </div>
    </main>
    <footer class="site-credit"><a href="https://mukipan.com" target="_blank" rel="noreferrer">Muki Pan</a></footer>
    <script type="application/json" id="archive-fallback-data" set:html={fallbackRecords}></script>
    <script type="application/json" id="supabase-config" set:html={supabaseConfig}></script>
    <script>import "../scripts/index-page.js";</script>
  </body>
</html>
